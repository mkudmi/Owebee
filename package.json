{
  "name": "owebee",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @owebee/api --filter @owebee/web dev",
    "dev:infra": "docker compose up -d postgres redis",
    "dev:all": "pnpm dev:infra && pnpm dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "typescript-eslint": "^8.39.1"
  }
}
